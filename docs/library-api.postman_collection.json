{
  "info": {
    "name": "Library API - Tech Case BTG Pactual",
    "description": "Fluxo principal da API de biblioteca digital: bootstrap, login, cadastro de dados, solicitação/aprovação de empréstimo, consulta de ativos, devolução e métricas operacionais.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "reader_token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    },
    {
      "key": "author_id",
      "value": ""
    },
    {
      "key": "book_id",
      "value": ""
    },
    {
      "key": "loan_request_id",
      "value": ""
    },
    {
      "key": "loan_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Bootstrap Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"strong-password\"\n}"
        },
        "url": "{{base_url}}/auth/bootstrap"
      }
    },
    {
      "name": "Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('admin_token', json.access_token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"strong-password\"\n}"
        },
        "url": "{{base_url}}/auth/login"
      }
    },
    {
      "name": "Create Library User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('user_id', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Reader\",\n  \"email\": \"reader@example.com\"\n}"
        },
        "url": "{{base_url}}/users/"
      }
    },
    {
      "name": "Create Reader Account",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Reader Account\",\n  \"email\": \"reader-account@example.com\",\n  \"password\": \"strong-password\",\n  \"role\": \"reader\",\n  \"user_id\": {{user_id}}\n}"
        },
        "url": "{{base_url}}/accounts/"
      }
    },
    {
      "name": "Login Reader",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('reader_token', json.access_token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"reader-account@example.com\",\n  \"password\": \"strong-password\"\n}"
        },
        "url": "{{base_url}}/auth/login"
      }
    },
    {
      "name": "Create Author",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('author_id', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Machado de Assis\"\n}"
        },
        "url": "{{base_url}}/authors/"
      }
    },
    {
      "name": "Create Book",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('book_id', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"isbn\": \"1234567890\",\n  \"author_id\": {{author_id}},\n  \"title\": \"Dom Casmurro\",\n  \"published_date\": \"1899-01-01\"\n}"
        },
        "url": "{{base_url}}/books/"
      }
    },
    {
      "name": "Request Loan",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('loan_request_id', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{reader_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"book_id\": {{book_id}}\n}"
        },
        "url": "{{base_url}}/loan-requests/"
      }
    },
    {
      "name": "Approve Loan Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": "{{base_url}}/loan-requests/{{loan_request_id}}/approve"
      }
    },
    {
      "name": "List Active Loans",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json.items && json.items.length > 0) {",
              "  pm.collectionVariables.set('loan_id', json.items[0].id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": "{{base_url}}/loans/active?skip=0&limit=100"
      }
    },
    {
      "name": "List Overdue Loans",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": "{{base_url}}/loans/overdue?skip=0&limit=100"
      }
    },
    {
      "name": "Return Loan",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": "{{base_url}}/loans/{{loan_id}}/return"
      }
    },
    {
      "name": "User Loan History",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": "{{base_url}}/users/{{user_id}}/loans?skip=0&limit=100"
      }
    },
    {
      "name": "Loan Metrics",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": "{{base_url}}/metrics/loans"
      }
    }
  ]
}
